# ============================================================
# API ID  : LLM-CHAT-API-001
# 기능명  : Repo Chat Run 생성 및 SSE 스트리밍
# Method  : POST
# Endpoint: /api/chat/{repo_id}/runs
# Auth    : 필요
# 관련 기능 ID: LLM-CHAT-B-101, LLM-CHAT-B-202,
#   LLM-CHAT-F-201, LLM-CHAT-F-202, LLM-CHAT-F-203,
#   LLM-CHAT-F-204, LLM-CHAT-F-205, LLM-CHAT-F-206,
#   LLM-TOOL-B-202, LLM-TOOL-B-203, LLM-TOOL-B-204,
#   LLM-TOOL-B-207 (Advanced Reasoning은 Phase 2 보류)
# 상태    : 구현 완료
#
# Description:
# 저장소에 대한 자연어 질문으로 run을 생성한 뒤 streamUrl에 SSE 연결.
# SSE 이벤트: graph_started | planner_plan | route_validated | worker_started |
# worker_result | evidence_compacted | answer_delta | references | completed | failed
# # curl 테스트:
# # curl -X POST http://localhost:8000/api/chat/{repo_id}/runs \
# #   -H 'Authorization: Bearer {token}' \
# #   -H 'Content-Type: application/json' \
# #   -d '{"question": "인증 미들웨어는 어디에 있나요?"}'
# # curl -N http://localhost:8000{streamUrl} \
# #   -H 'Authorization: Bearer {token}' \
# #   -H 'Accept: text/event-stream'
# ============================================================

@baseUrl = http://localhost:8000
@accessToken = replace-me
@repo_id = replace-me-repo_id
@run_id = replace-me-run_id

### 정상 요청 - Run 생성
POST {{baseUrl}}/api/chat/{{repo_id}}/runs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "question": "인증 미들웨어는 어디에 있고 어떻게 동작하나요?",
  "maxToolCalls": 5,
  "timeoutSeconds": 20
}

# Success Response: 202 Accepted
# {
#   "code": 202,
#   "message": "accepted",
#   "data": {
#     "runId": "...",
#     "sessionId": "...",
#     "status": "queued",
#     "streamUrl": "/api/chat/{repo_id}/runs/{run_id}/stream",
#     "statusUrl": "/api/chat/{repo_id}/runs/{run_id}",
#     "evidenceUrl": "/api/chat/{repo_id}/runs/{run_id}/evidence"
#   }
# }

### 정상 요청 - SSE Stream 연결
GET {{baseUrl}}/api/chat/{{repo_id}}/runs/{{run_id}}/stream
Authorization: Bearer {{accessToken}}
Accept: text/event-stream

# Success Response: SSE Stream
# event: graph_started
# data: {"runId":"...","stateKeys":["user_query"]}
#
# event: worker_started
# data: {"worker":"search","target":null}
#
# event: answer_delta
# data: {"content": "인증 미들웨어는"}
#
# event: completed
# data: {"runId":"...","status":"completed"}


### 에러 케이스 - 인증 없음
POST {{baseUrl}}/api/chat/{{repo_id}}/runs
Content-Type: application/json

{}

# 연결 전 오류 응답은 표준 HTTP 오류 envelope를 사용한다.
# {"code":401,"message":"인증이 필요합니다.","data":null,"error":{"code":"UNAUTHORIZED","detail":null,"field":null,"retryable":false}}
# 401 UNAUTHORIZED: 토큰 누락/만료
# 404 REPO_NOT_FOUND: 저장소 없음
# 404 EMBEDDING_NOT_READY: 임베딩 미완료
# 422 QUESTION_TOO_LONG: 질문 최대 길이 초과
# 500 AGENT_INTERNAL_ERROR: LLM/도구 실행 오류
# 스트림 시작 후 오류는 HTTP status 대신 SSE error event로 발행한다.
# event: error
# data: {"code":"AGENT_INTERNAL_ERROR","message":"답변 생성 중 오류가 발생했습니다.","retryable":true}
